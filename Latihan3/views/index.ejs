<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <title>Daftar Buku</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
  <style> body { font-family: 'Plus Jakarta Sans', sans-serif; } </style>
</head>
<body class="bg-slate-900 text-slate-100 min-h-screen p-6">
  <div class="max-w-4xl mx-auto">
    <!-- Navbar -->
    <div class="flex flex-col md:flex-row justify-between items-center mb-8 gap-4 border-b border-slate-800 pb-6">
      <a href="/" class="text-2xl font-bold text-white">Data Buku</a>
      <div class="flex gap-2">
        <a href="/" class="px-4 py-2 bg-indigo-600 text-white rounded-lg text-sm font-semibold shadow">Semua Data</a>
        <a href="/books" class="px-4 py-2 bg-slate-800 hover:bg-slate-700 text-slate-300 rounded-lg text-sm font-semibold border border-slate-700">Buku</a>
        <a href="/authors" class="px-4 py-2 bg-slate-800 hover:bg-slate-700 text-slate-300 rounded-lg text-sm font-semibold border border-slate-700">Author</a>
      </div>
    </div>

    <!-- Tombol Tambah -->
    <div class="mb-6">
      <a href="/tambah" class="bg-emerald-600 hover:bg-emerald-500 text-white px-5 py-2.5 rounded-lg text-sm font-semibold shadow transition inline-flex items-center gap-2">
        <span>+</span> Tambah
      </a>
    </div>

    <% 
      const authorMap = {};
      authors.forEach(a => authorMap[a.id] = a.name);
    %>

    <!-- List Semua Data Dalam 1 Kartu / 1 Kolom -->
    <section class="space-y-4">
      <h2 class="text-xl font-bold mb-4 text-indigo-400">Semua Data Buku</h2>
      
      <div class="grid grid-cols-1 gap-3">
        <% books.forEach(book => { %>
          <div class="bg-slate-800 border border-slate-700 p-4 rounded-xl flex flex-col md:flex-row md:items-center justify-between gap-4">
            <!-- Informasi Gabungan (Buku, Penulis, Genre dalam 1 Baris / Kolom) -->
            <div class="flex flex-col md:flex-row md:items-center gap-2 md:gap-6">
              <div>
                <span class="text-xs text-slate-400">Judul Buku:</span>
                <p class="font-bold text-white text-base"><%= book.title %></p>
              </div>
              <div class="hidden md:block text-slate-600">|</div>
              <div>
                <span class="text-xs text-slate-400">Penulis:</span>
                <p class="font-medium text-indigo-300 text-sm"><%= authorMap[book.authorId] || 'Tidak diketahui' %></p>
              </div>
              <div class="hidden md:block text-slate-600">|</div>
              <div>
                <span class="text-xs text-slate-400">Genre:</span>
                <p class="font-medium text-emerald-400 text-sm"><%= book.genre %></p>
              </div>
            </div>

            <!-- Tombol Action (Edit & Hapus) -->
            <div class="flex gap-2 justify-end border-t border-slate-700/50 md:border-t-0 pt-3 md:pt-0">
              <a href="/edit?id=<%= book.id %>" class="px-3 py-1.5 bg-amber-500/10 text-amber-400 rounded text-xs font-semibold hover:bg-amber-500/20 border border-amber-500/20">Edit</a>
              <form action="/books/<%= book.id %>?_method=DELETE" method="POST" onsubmit="return confirm('Hapus buku ini?')">
                <button type="submit" class="px-3 py-1.5 bg-rose-500/10 text-rose-400 rounded text-xs font-semibold hover:bg-rose-500/20 border border-rose-500/20">Hapus</button>
              </form>
            </div>
          </div>
        <% }) %>
      </div>
    </section>
  </div>
</body>
</html>